<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base application theme. DayNight so native UI follows the system
         light/dark mode. (No DarkActionBar: it forced the text-selection
         action mode / menus to render dark regardless of mode.) -->
    <style name="AppTheme" parent="Theme.AppCompat.DayNight">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="colorBackgroundFloating">@color/floatingToolbarBackground</item>
        <item name="android:colorBackgroundFloating">@color/floatingToolbarBackground</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">@null</item>
        <!-- The web app manages its own light/dark theme, so the OS must not
             force-dark the WebView content. -->
        <item name="android:forceDarkAllowed" tools:targetApi="29">false</item>
        <!-- Adaptive background for the native text-selection floating toolbar:
             light from values/, dark from values-night/ (follows system mode). -->
        <item name="colorBackgroundFloating">@color/floatingToolbarBackground</item>
        <item name="android:colorBackgroundFloating">@color/floatingToolbarBackground</item>
    </style>

    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="android:background">@drawable/splash</item>
        <!-- After the splash, run on the DayNight main theme. -->
        <item name="postSplashScreenTheme">@style/AppTheme.NoActionBar</item>
    </style>
</resources>
