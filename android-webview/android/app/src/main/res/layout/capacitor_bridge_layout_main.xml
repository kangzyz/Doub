<?xml version="1.0" encoding="utf-8"?>
<!--
  App-level override of Capacitor's bundled capacitor_bridge_layout_main.xml.
  Identical to the upstream layout, except the WebView is our
  NoSelectionMenuWebView subclass, which suppresses the native/OEM
  text-selection floating toolbar. The android:id MUST stay @+id/webview so the
  Capacitor bridge finds it via R.id.webview.
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="com.getcapacitor.BridgeActivity"
    >

    <cloud.helpking.doub.NoSelectionMenuWebView
        android:id="@+id/webview"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
