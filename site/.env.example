# Cloudflare credentials for `pnpm cf:deploy`.
# Copy this file to `.env` (gitignored) and fill in real values.
#
# 1. CLOUDFLARE_API_TOKEN
#    Create at: https://dash.cloudflare.com/profile/api-tokens
#    Template:  "Edit Cloudflare Workers"  (already includes Pages permission)
#
# 2. CLOUDFLARE_ACCOUNT_ID
#    Find on the Workers & Pages overview page (right sidebar).

CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
